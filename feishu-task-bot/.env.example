# ============================================
# 飞书AI群聊任务助手 - 环境配置
# ============================================

# --- 飞书应用配置 ---
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 事件订阅验证 Token（飞书后台获取）
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 事件订阅 Encrypt Key（可选，建议配置以增强安全性）
FEISHU_ENCRYPT_KEY=

# --- AI 配置 ---
# 支持 openai / dashscope (通义千问) / custom
AI_PROVIDER=dashscope
AI_API_KEY=your_api_key_here
AI_MODEL=qwen-plus
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 多维表格配置 ---
# 多维表格 app_token（从URL中获取）
BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxx

# 数据表 table_id
BITABLE_TABLE_ID=tblxxxxxxxxxxxxxx

# --- 服务配置 ---
PORT=3000
HOST=0.0.0.0

# 日志级别: error / warn / info / debug
LOG_LEVEL=info

# 每日汇总时间（cron 表达式，默认每天18:00）
DAILY_SUMMARY_CRON=0 18 * * *

# 时区
TIMEZONE=Asia/Shanghai

# --- 监控的群聊列表（逗号分隔的 chat_id）---
# 机器人加入群后可通过 API 获取 chat_id
MONITORED_CHAT_IDS=oc_xxxxxxxxxxxxx1,oc_xxxxxxxxxxxxx2
